{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Read(**/credentials/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(~/.openclaw/credentials/**)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.production)",
      "Edit(**/.env)",
      "Edit(**/.env.local)",
      "Edit(**/.env.production)",
      "Bash(cat .env)",
      "Bash(cat .env.local)",
      "Bash(cat .env.production)",
      "Bash(cat **/.env)",
      "Bash(head .env)",
      "Bash(tail .env)",
      "Bash(less .env)",
      "Bash(more .env)",
      "Bash(grep * .env)",
      "Bash(sed * .env)",
      "Bash(awk * .env)",
      "Bash(source .env)",
      "Bash(source .env.local)",
      "Bash(source .env.production)",
      "Bash(. .env)",
      "Bash(. .env.local)",
      "Bash(. .env.production)",
      "Bash(cat *credentials*)",
      "Bash(cat *.pem)",
      "Bash(cat *.key)"
    ]
  }
}
